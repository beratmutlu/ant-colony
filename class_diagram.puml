@startuml colony_class_diagram

' ─── Appearance ────────────────────────────────────────
skinparam backgroundColor #FEFEFE
skinparam classBackgroundColor #F7F9FC
skinparam classBorderColor #4A6FA5
skinparam classFontSize 13
skinparam classAttributeFontSize 11
skinparam packageBackgroundColor #EEF2F7
skinparam packageBorderColor #8DA4C2
skinparam packageFontSize 14
skinparam packageStyle rectangle
skinparam arrowColor #4A6FA5
skinparam stereotypeCBackgroundColor #D6E4F0
skinparam shadowing false
skinparam nodesep 50
skinparam ranksep 45

title **colony/ — Class Diagram**

' ═══════════════════════════════════════════════════════
'  TYPES
' ═══════════════════════════════════════════════════════
package "types" as pkg_types {

    enum ItemType <<enum>> {
        FOOD
        PHEROMONE_NEST
        PHEROMONE_FOOD
        --
        + decays : bool
        + decay_rate : float
    }
}

' ═══════════════════════════════════════════════════════
'  CORE
' ═══════════════════════════════════════════════════════
package "core" as pkg_core {

    class Simulation {
        + config : dict
        + manager : Manager
        + events_by_tick : dict
        --
        + load(path: str) : void
        + load_dict(config: dict) : void
        + build() : void
        + step() : void
        + run(steps: int) : void
    }

    class Manager {
        + grid : Grid
        + nest_pos : tuple[int, int]
        + ph_strength : float
        + tick : int
        + ants : list[Ant]
        + food_delivered : float
        + score : int
        --
        + tick_clock() : void
    }

    class Grid {
        + width : int
        + height : int
        + cells : dict[pos, Cell]
        --
        + get_cell(x, y) : Cell
        + get_neighbours(cell) : dict
        + set_ant_capacity(pos, val) : void
        + clear_pheromones(pos) : void
        + tick_decay() : void
    }

    class Cell {
        + pos : tuple[int, int]
        + cap_ant : int
        + cap_item : int
        + items : dict[ItemType, float]
        --
        + add_item(item, amount) : void
        + remove_item(item, amount) : void
        + get_food() : float
        + get_pheromones() : dict
        + clear_pheromones() : void
        + decay_all() : void
    }

    Simulation o-down- "1" Manager : orchestrates
    Manager o-down- "1" Grid
    Grid *-down- "many" Cell : contains
}

' ═══════════════════════════════════════════════════════
'  AGENTS
' ═══════════════════════════════════════════════════════
package "agents" as pkg_agents {

    class Ant {
        + cell : Cell
        + energy : float
        + carrying : bool
        + score : int
        + memory : list[tuple]
        + determinism : float
        + route_len : int
        --
        + sense(percept: Percept) : void
        + reason() : Action
    }

    class Percept <<dataclass>> {
        + carrying : bool
        + energy : float
        + last_action_ok : bool
        + food_present : bool
        + nest_present : bool
        + neighbor_pheromones : dict
        + neighbors_passable : dict
        + nest_adjacent : dict
        + food_adjacent : dict
    }

    class Action <<dataclass>> {
        + type : ActionType
        + direction : Direction?
    }

    enum ActionType <<enum>> {
        MOVE
        PICK_UP
        DROP
        IDLE
    }

    enum Direction <<enum>> {
        N | NE | E | SE
        S | SW | W | NW
        --
        + apply(pos) : tuple
    }

    Ant .down.> Percept : consumes
    Ant .down.> Action : produces
    Action .down.> ActionType
    Action .down.> Direction
}

' ═══════════════════════════════════════════════════════
'  CROSS-PACKAGE
' ═══════════════════════════════════════════════════════
Manager -right-> "many" Ant : manages
Cell ..> ItemType : stores

@enduml
